# ============================================================
# TradingView AI Social Media Automation — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# --- Application ---
NODE_ENV=development
PORT=4000
API_SECRET_KEY=change-me-to-a-random-32-char-string
FRONTEND_URL=http://localhost:3000

# --- Database (Supabase) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# --- Redis (optional — workers disabled if unavailable) ---
REDIS_URL=redis://localhost:6379

# --- TradingView Session ---
# Export these from your browser's cookies for tradingview.com
# Do NOT use username/password — system uses cookie injection to bypass anti-bot
TV_SESSION_ID=your-tradingview-sessionid-cookie
TV_SESSION_ID_SIGN=your-tradingview-sessionid-sign-cookie

# --- AI Models ---
GEMINI_API_KEY=your-google-ai-api-key
OPENAI_API_KEY=your-openai-api-key
AI_PRIMARY_MODEL=gemini

# --- Cloudinary ---
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# --- Meta (Facebook + Instagram) ---
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret
META_PAGE_ACCESS_TOKEN=your-long-lived-page-access-token
META_PAGE_ID=your-facebook-page-id
META_IG_USER_ID=your-instagram-business-user-id

# --- WhatsApp Business ---
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_ACCESS_TOKEN=your-whatsapp-access-token
WHATSAPP_TEMPLATE_NAME=chart_update

# --- Next.js Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_API_SECRET=change-me-to-match-API_SECRET_KEY
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key
