{
  "name": "chartpost-backend",
  "version": "1.0.0",
  "description": "TradingView AI Social Media Automation — Backend API & Workers",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "lint": "eslint",
    "test": "jest --runInBand --forceExit",
    "test:unit": "jest --testPathPattern=tests/unit --runInBand",
    "test:integration": "jest --testPathPattern=tests/integration --runInBand",
    "test:api": "jest --testPathPattern=tests/api --runInBand",
    "test:e2e": "jest --testPathPattern=tests/e2e --runInBand",
    "test:security": "jest --testPathPattern=tests/security --runInBand",
    "test:error-paths": "jest --testPathPattern=tests/error-paths --runInBand",
    "test:coverage": "jest --coverage --runInBand",
    "test:smoke": "node scripts/smoke-test.js",
    "migrate": "node scripts/run-migration.js",
    "seed": "tsx scripts/migrate.ts"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "@supabase/supabase-js": "^2.49.0",
    "bullmq": "^5.34.0",
    "cloudinary": "^2.5.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.1",
    "morgan": "^1.10.0",
    "node-cron": "^3.0.3",
    "openai": "^4.73.0",
    "playwright": "^1.49.0",
    "uuid": "^11.0.0",
    "winston": "^3.17.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.9.0",
    "@types/node-cron": "^3.0.11",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.14.0",
    "@typescript-eslint/parser": "^8.14.0",
    "eslint": "^9.14.0",
    "jest": "^29.7.0",
    "pg": "^8.21.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.0"
  }
}
