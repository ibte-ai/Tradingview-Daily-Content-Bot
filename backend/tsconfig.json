{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "moduleResolution": "node",
    "baseUrl": "./src",
    "types": ["jest", "node"],
    "paths": {
      "@config/*": ["config/*"],
      "@services/*": ["services/*"],
      "@routes/*": ["routes/*"],
      "@workers/*": ["workers/*"],
      "@models/*": ["models/*"],
      "@utils/*": ["utils/*"],
      "@middleware/*": ["middleware/*"]
    }
  },
  "include": ["src/**/*", "tests/**/*"],
  "exclude": ["node_modules", "dist"]
}
